{
  "name": "shru-design-system",
  "version": "0.6.2",
  "description": "A React component library built with Tailwind CSS",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "dev": "npm run dev --prefix ./test",
    "build": "node scripts/copy-tokens.js && tsup src/index.ts --dts --format esm,cjs && node scripts/copy-styles.js",
    "check": "node scripts/check.js",
    "check:metadata": "node scripts/check-metadata-props.js",
    "prepublishOnly": "npm run check",
    "postinstall": "node scripts/init.js || true"
  },
  "bin": {
    "shru-design-system-init": "./scripts/init.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tailwind-preset": "./scripts/tailwind.preset.cjs"
  },
  "peerDependencies": {
    "@radix-ui/react-slider": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "input-otp": "^1.0.0",
    "lucide-react": "^0.400.0",
    "react": ">=18",
    "react-dom": ">=18",
    "react-resizable-panels": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@radix-ui/react-slider": "^1.2.2",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.23",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.400.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3"
  },
  "license": "MIT",
  "keywords": [
    "react",
    "components",
    "design-system",
    "tailwind",
    "ui-components"
  ]
}
